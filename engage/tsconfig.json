{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./engage/dist",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["./engage/shared/*"],
      "@/*": ["./engage/client/src/*"]
    }
  },
  "include": ["engage/**/*"],
  "exclude": ["node_modules", "engage/dist"]
}
