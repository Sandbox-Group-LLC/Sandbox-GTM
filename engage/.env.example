# Database
DATABASE_URL=postgresql://user:password@host/engage_db?sslmode=require

# Session
SESSION_SECRET=change-me-to-a-random-string

# Platform Adapter: rainfocus | cvent | eventbrite
PLATFORM_ADAPTER=rainfocus

# Rainfocus
RAINFOCUS_API_URL=https://api.rainfocus.com
RAINFOCUS_API_KEY=
RAINFOCUS_PROFILE_ID=

# Server
PORT=3001
NODE_ENV=development
